# ──────────────────────────────────────────────────────────────
# vinhlong360 Knowledge Agent — Environment Variables
#
# STATUS (2026-07-07): active — đã truth-sync. Block "HAS_* feature flags" cũ
# (vốn mô tả sai cơ chế) đã được thay bằng đính chính ở cuối file.
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control (it contains secrets).
# ──────────────────────────────────────────────────────────────

# ── LLM / AI Provider ───────────────────────────────────────
# API key for the ChatGPT-compatible LLM endpoint
LLM_API_KEY=sk-your-api-key-here

# Base URL of the LLM API (OpenAI-compatible /v1 endpoint)
LLM_BASE_URL=https://your-llm-provider.example.com/v1

# Primary model for chat, tool-calling, and agentic reasoning
LLM_MODEL=cx/gpt-5.5

# Smaller/cheaper model for classification, autocorrect, and batch tasks
# LƯU Ý: đặt model RẺ thật ở đây (khác LLM_MODEL) để cắt chi phí — SearchAgent/General dùng mini.
LLM_MODEL_MINI=cx/gpt-5.5-mini

# Model cho data enrichment scripts (enrich_with_llm.py). Mặc định = LLM_MODEL.
# LLM_MODEL_ENRICH=cx/gpt-5.5

# GĐ4.4: LLM Judge chấm điểm chất lượng = thêm 1 lượt LLM/chat (telemetry). Mặc định TẮT để tiết kiệm.
LLM_JUDGE_ENABLED=false

# ── Environment ─────────────────────────────────────────────
# Set to "production" on VPS to enable prod guards (stricter CORS, gate internal endpoints)
# ENVIRONMENT=development

# ── Admin & Security ────────────────────────────────────────
# Secret key for the /admin/* API endpoints.
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8360,http://localhost:3000,https://vinhlong360.vn

# CSRF secret for auth token signing (auto-generated if empty)
# CSRF_SECRET=

# ── Telegram Bot ─────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs with admin bot access
# ADMIN_TELEGRAM_IDS=

# ── Zalo OA (Official Account) ──────────────────────────────
# Register at https://oa.zalo.me and get credentials from API settings
ZALO_OA_ID=
ZALO_OA_SECRET=

# ── External Services ───────────────────────────────────────
# OpenWeatherMap API key for real-time weather data
# Get a free key at https://openweathermap.org/api
WEATHER_API_KEY=

# Internal URL of the agent server (used by bot_gateway to call /chat)
AGENT_URL=http://localhost:8360

# Redis connection URL for caching / rate-limiting (optional)
# If not set, the agent uses in-memory caches instead.
REDIS_URL=

# ── Memory Encryption ──────────────────────────────────────
# Fernet key for encrypting cold memory (user profiles) at rest.
# If not set, a key is auto-generated and saved to agent/data/memory/.key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEMORY_ENCRYPTION_KEY=

# ── Database (Phase 0) ─────────────────────────────────────
# PostgreSQL connection URL. If not set, falls back to SQLite (dev mode).
DATABASE_URL=postgresql://vl360:change_me@localhost:5432/vinhlong360

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=change_me

# Runtime operations
# Set false for quick local smoke tests that do not need enhanced search indexes.
BUILD_SEARCH_INDEXES=true

# Set false when deployment readiness should wait for search indexes to finish.
BACKGROUND_INDEX_BUILD=true

# Set false to disable the in-process background scheduler.
SCHEDULER_ENABLED=true

# Keep false in production so autonomous jobs do not run immediately on boot.
SCHEDULER_RUN_STARTUP_TASKS=false

# Set false to disable autonomous learning/evolution jobs while keeping simple tasks.
# Mặc định FALSE cho dự án ngân sách thấp: các job này gọi LLM 24/7 dù không có user (GĐ0.4).
SCHEDULER_ENABLE_AUTONOMOUS_TASKS=false

# GĐ0.5: khoá thao tác phá dữ liệu (/reload, /admin/data-quality/apply|rollback, db replace).
# Mặc định "1" (khoá) trong giai đoạn ổn định. Mở thành "0" ở GĐ3.8 sau khi DB là nguồn sự thật.
DESTRUCTIVE_OPS_LOCKED=1

# LLM request timeout in seconds
# LLM_TIMEOUT=30

# PostgreSQL connection pool max size (only when PG_USE_POOL=true)
# PG_POOL_MAX=10

# Auth: max concurrent sessions per user, lockout thresholds
# MAX_SESSIONS_PER_USER=5
# LOCKOUT_THRESHOLD=5
# LOCKOUT_DURATION=900
# LOCKOUT_WINDOW=300

# Autonomous agent (CLAUDE.md §B8): opt-in nền + cap cứng/ngày, đọc trực tiếp bởi
# agent/autonomous_budget.py. Mặc định TẮT — chỉ bật khi chủ dự án quyết.
# AUTONOMOUS_AGENT_ENABLED=false
# AUTONOMOUS_AGENT_MAX_CALLS_PER_DAY=20

# ── OTP SMS Authentication (Phase 0) ──────────────────────
# eSMS.vn credentials for OTP SMS delivery
# Register at https://esms.vn and get API key/secret from dashboard
ESMS_API_KEY=
ESMS_SECRET=
ESMS_BRANDNAME=VinhLong360

# ── Object Storage (Phase 0) ──────────────────────────────
# S3-compatible storage for user-uploaded images (Bizfly Object Storage)
S3_ENDPOINT=https://hn.ss.bfcplatform.vn
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vinhlong360-media
S3_REGION=hn

# ── Monitoring ──────────────────────────────────────────────
# Grafana admin password (change in production!)
# GRAFANA_ADMIN_PASSWORD=admin

# ── Module flags: HAS_* KHÔNG phải env var ──────────────────
# ĐÍNH CHÍNH (truth-sync 2026-07-07): các tên HAS_* (HAS_GUARDRAILS, HAS_METRICS,
# HAS_PROMPT_CACHE...) là BIẾN PYTHON đặt bằng try-import trong agent/server.py:87-248,
# KHÔNG được đọc từ environment. Đặt HAS_X=true/false ở đây là VÔ TÁC DỤNG.
# Mọi module import OK trên codebase hiện tại → tất cả đang BẬT sẵn (dev lẫn prod).
# Muốn tắt một module = sửa code (gỡ import) + redeploy. Xem docs/module-activation-guide.md.
# Các env flag CÓ THẬT: LLM_JUDGE_ENABLED (trên đầu file), BUILD_SEARCH_INDEXES,
# BACKGROUND_INDEX_BUILD, SCHEDULER_ENABLED, SCHEDULER_ENABLE_AUTONOMOUS_TASKS,
# AUTONOMOUS_AGENT_ENABLED, AUTONOMOUS_AGENT_MAX_CALLS_PER_DAY (mục Database/Runtime ở trên).

# ── Off-site Backup ────────────────────────────────────────
# S3-compatible storage for off-site backups (uses same S3_* vars as media storage)
# BACKUP_S3_PREFIX=vl360-backups/
