# ──────────────────────────────────────────────────────────────
# vinhlong360 Knowledge Agent — Environment Variables
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control (it contains secrets).
# ──────────────────────────────────────────────────────────────

# ── LLM / AI Provider ───────────────────────────────────────
# API key for the ChatGPT-compatible LLM endpoint
LLM_API_KEY=sk-your-api-key-here

# Base URL of the LLM API (OpenAI-compatible /v1 endpoint)
LLM_BASE_URL=https://your-llm-provider.example.com/v1

# Primary model for chat, tool-calling, and agentic reasoning
LLM_MODEL=cx/gpt-5.4

# Smaller/cheaper model for classification, autocorrect, and batch tasks
LLM_MODEL_MINI=cx/gpt-5.4-mini

# ── Admin & Security ────────────────────────────────────────
# Secret key for the /admin/* API endpoints.
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8360,http://localhost:3000,https://vinhlong360.vn

# ── Telegram Bot ─────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Zalo OA (Official Account) ──────────────────────────────
# Register at https://oa.zalo.me and get credentials from API settings
ZALO_OA_ID=
ZALO_OA_SECRET=

# ── External Services ───────────────────────────────────────
# OpenWeatherMap API key for real-time weather data
# Get a free key at https://openweathermap.org/api
WEATHER_API_KEY=

# Internal URL of the agent server (used by bot_gateway to call /chat)
AGENT_URL=http://localhost:8360

# Redis connection URL for caching / rate-limiting (optional)
# If not set, the agent uses in-memory caches instead.
REDIS_URL=

# ── Memory Encryption ──────────────────────────────────────
# Fernet key for encrypting cold memory (user profiles) at rest.
# If not set, a key is auto-generated and saved to agent/data/memory/.key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEMORY_ENCRYPTION_KEY=

# ── Database (Phase 0) ─────────────────────────────────────
# PostgreSQL connection URL. If not set, falls back to SQLite (dev mode).
DATABASE_URL=postgresql://vl360:change_me@localhost:5432/vinhlong360

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=change_me

# Runtime operations
# Set false for quick local smoke tests that do not need enhanced search indexes.
BUILD_SEARCH_INDEXES=true

# Set false when deployment readiness should wait for search indexes to finish.
BACKGROUND_INDEX_BUILD=true

# Set false to disable the in-process background scheduler.
SCHEDULER_ENABLED=true

# Keep false in production so autonomous jobs do not run immediately on boot.
SCHEDULER_RUN_STARTUP_TASKS=false

# Set false to disable autonomous learning/evolution jobs while keeping simple tasks.
# Mặc định FALSE cho dự án ngân sách thấp: các job này gọi LLM 24/7 dù không có user (GĐ0.4).
SCHEDULER_ENABLE_AUTONOMOUS_TASKS=false

# ── OTP SMS Authentication (Phase 0) ──────────────────────
# eSMS.vn credentials for OTP SMS delivery
# Register at https://esms.vn and get API key/secret from dashboard
ESMS_API_KEY=
ESMS_SECRET=
ESMS_BRANDNAME=VinhLong360

# ── Object Storage (Phase 0) ──────────────────────────────
# S3-compatible storage for user-uploaded images (Bizfly Object Storage)
S3_ENDPOINT=https://hn.ss.bfcplatform.vn
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vinhlong360-media
S3_REGION=hn
