{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agent",
      "runtimeExecutable": "python",
      "runtimeArgs": ["agent/server.py"],
      "port": 8360
    },
    {
      "name": "bots",
      "runtimeExecutable": "python",
      "runtimeArgs": ["agent/bot_gateway.py"],
      "port": 8361
    },
    {
      "name": "nuxt",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web-nuxt"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "API_BASE": "https://vinhlong360.vn"
      }
    },
    {
      "name": "nuxt-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["web-nuxt/.output/server/index.mjs"],
      "port": 3000
    }
  ]
}
