---
import { getPlace, getAreaName, isInSeason, TYPE_META, type Entity } from '../data/store';

interface Props {
  entity: Entity;
  currentMonth?: number;
}

const { entity, currentMonth = new Date().getMonth() + 1 } = Astro.props;
const meta = TYPE_META[entity.type] ?? { emoji: '•', label: entity.type };
const place = getPlace(entity);
const inSeason = isInSeason(entity, currentMonth);
const isYearRound = !entity.season || entity.season.months?.length >= 12;
const ocop = entity.attributes?.ocop;
---
<a class={`card cat-${entity.type}`} href={`/dia-diem/${entity.id}`}>
  <div class={`cover cat-${entity.type}`}><span>{meta.emoji}</span></div>
  <div class="card-b">
    <span class="card-type">{meta.label}</span>
    <h3>{entity.name}</h3>
    {entity.summary && <p class="summary">{entity.summary}</p>}
    {place && <p class="place">📍 {place.name}{place.legacyArea ? ` (${place.legacyArea} cũ)` : ''}</p>}
    <div class="badges">
      {inSeason && entity.season?.peak?.includes(currentMonth) && <span class="badge peak">🔥 Đang rộ</span>}
      {isYearRound ? <span class="badge year">Quanh năm</span> : entity.season && <span class="badge season">T{entity.season.months[0]}–{entity.season.months[entity.season.months.length - 1]}</span>}
      {ocop && <span class="badge ocop">⭐ {ocop}</span>}
    </div>
  </div>
</a>
