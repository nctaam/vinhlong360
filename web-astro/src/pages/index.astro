---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntityCard from '../components/EntityCard.astro';
import { getCardEntities, isInSeason, getItineraries, getPlace, AREA_META } from '../data/store';

const month = new Date().getMonth() + 1;
const cards = getCardEntities();
const inSeason = cards.filter(e => isInSeason(e, month) && e.season?.peak?.includes(month)).slice(0, 6);
const itineraries = getItineraries().slice(0, 4);
const placeIds = new Set(cards.filter(e => e.placeId).map(e => e.placeId));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "vinhlong360",
  "url": "https://vinhlong360.vn",
  "description": "Cổng du lịch & sản phẩm địa phương Vĩnh Long — Trà Vinh — Bến Tre",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://vinhlong360.vn/tim-kiem?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---
<BaseLayout title="Du lịch & Sản phẩm địa phương Vĩnh Long" jsonLd={jsonLd}>
  <section class="hero">
    <h1>Khám phá Vĩnh Long<br/>theo cách của người bản địa</h1>
    <p>Trải nghiệm miệt vườn, đặc sản theo mùa, làng nghề và lịch trình gợi ý — tất cả trong một bản đồ.</p>
    <form class="hero-search" action="/tim-kiem" method="get">
      <input type="search" name="q" class="input" placeholder="Tìm: chôm chôm, kẹo dừa, cù lao An..." />
      <button type="submit" class="btn btn-primary">Tìm</button>
    </form>
    <p class="hero-stats">🗂 {cards.length} điểm dữ liệu &nbsp; 📍 {placeIds.size} xã/phường &nbsp; 🗺️ {itineraries.length} lịch trình</p>
  </section>

  {inSeason.length > 0 && (
    <section class="block">
      <div class="section-head">
        <h2>🔥 Đang vào mùa tháng {month}</h2>
        <a class="see-all" href="/du-lich">Xem tất cả →</a>
      </div>
      <div class="grid">
        {inSeason.map(e => <EntityCard entity={e} currentMonth={month} />)}
      </div>
    </section>
  )}

  <section class="block">
    <div class="section-head">
      <h2>Khám phá theo khu vực</h2>
    </div>
    <div class="region-grid">
      {Object.entries(AREA_META).map(([key, meta]) => {
        const count = cards.filter(e => {
          const place = getPlace(e);
          return (place?.area ?? e.area) === key;
        }).length;
        return (
          <a class="region-card" href={`/khu-vuc/${key}`}>
            <span class="rc-emoji">{meta.emoji}</span>
            <h3>Khu vực {meta.name}</h3>
            <span class="rc-count">{count} mục →</span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
